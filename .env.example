# ─── COPY THIS FILE TO .env.local — NEVER commit .env.local ───────────────────

# ── Deployer (for Hardhat deploy script) ──────────────────────────────────────
# Your wallet's private key. Export from Coinbase Wallet or MetaMask.
# NEVER share this or commit it to git.
DEPLOYER_PRIVATE_KEY=0xYOUR_PRIVATE_KEY_HERE

# ── RPC URLs ──────────────────────────────────────────────────────────────────
# Free tier at alchemy.com or quicknode.com (Base Sepolia)
RPC_URL=https://base-sepolia.g.alchemy.com/v2/YOUR_ALCHEMY_KEY
RPC_URL_MAINNET=https://base-mainnet.g.alchemy.com/v2/YOUR_ALCHEMY_KEY

# ── Basescan (for contract verification) ──────────────────────────────────────
# Free API key at https://basescan.org/register
BASESCAN_API_KEY=YOUR_BASESCAN_API_KEY

# ── Frontend (exposed to browser — prefix NEXT_PUBLIC_) ───────────────────────
# Network: "mainnet" or "sepolia" (default: sepolia for hackathon)
NEXT_PUBLIC_NETWORK=sepolia

# Contract address — filled in automatically by deploy script
NEXT_PUBLIC_CONTRACT_ADDRESS=0x0000000000000000000000000000000000000000

# RPC URL for frontend (same as above — Vercel keeps this server-side via API routes)
NEXT_PUBLIC_RPC_URL=https://base-sepolia.g.alchemy.com/v2/YOUR_ALCHEMY_KEY

# OnchainKit API key — get free at https://portal.cdp.coinbase.com
NEXT_PUBLIC_ONCHAINKIT_API_KEY=YOUR_ONCHAINKIT_API_KEY
